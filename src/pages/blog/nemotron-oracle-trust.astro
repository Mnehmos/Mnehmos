  {fen:"3R4/5pk1/6p1/7p/1nPQP3/2P2P2/7K/4RB2 b - - 2 33",san:"Qd4+",moveNum:33,color:"w",label:"33. Qd4+"},
  {fen:"3R4/6k1/5pp1/7p/1nPQP3/2P2P2/7K/4RB2 w - - 0 34",san:"f6",moveNum:33,color:"b",label:"33... f6"},
  {fen:"3R4/6k1/5pp1/7p/1PPQP3/5P2/7K/4RB2 b - - 0 34",san:"cxb4",moveNum:34,color:"w",label:"34. cxb4"},
  {fen:"3R4/5k2/5pp1/7p/1PPQP3/5P2/7K/4RB2 w - - 1 35",san:"Kf7",moveNum:34,color:"b",label:"34... Kf7"},
  {fen:"3R4/3Q1k2/5pp1/7p/1PP1P3/5P2/7K/4RB2 b - - 2 35",san:"Qd7#",moveNum:35,color:"w",label:"35. Qd7#"},
];

const gpt54KeyMoments = [
  { posIndex: 0, tag: "Opening", desc: "King's Indian Classical. White has big center (c4/d4/e4), Black challenges with e5.", color: "bg-green-500/15 text-green-600 dark:text-green-400 border-green-500/20" },
  { posIndex: 1, tag: "7. O-O", desc: "Sensible consolidation. King safety first, then squeeze. Matches engine recommendation.", evalCp: "+0.62", color: "bg-green-500/15 text-green-600 dark:text-green-400 border-green-500/20" },
  { posIndex: 9, tag: "11. f3", desc: "Three jobs at once: blocks Bg4 diagonal, reinforces e4, questions Black's bishop.", evalCp: "+0.90", color: "bg-blue-500/15 text-blue-600 dark:text-blue-400 border-blue-500/20" },
  { posIndex: 15, tag: "14. Ndb5", desc: "Knight jumps to b5, increasing pressure on d6 weakness. Exploits Black's loosened dark squares after ...c5.", evalCp: "+2.53", color: "bg-amber-500/15 text-amber-600 dark:text-amber-400 border-amber-500/20" },
  { posIndex: 19, tag: "16. Nxd6 -- Knockout", desc: "Genuine knockout blow. Knight plants on d6 with tempo against Re8 and Bc8. Multiple problems at once.", evalCp: "+4.08", color: "bg-copper/15 text-copper border-copper/20" },
  { posIndex: 21, tag: "17. Nxc8", desc: "Cashes in the invading knight for Black's bishop. Clean conversion -- no sentiment about the outpost.", evalCp: "+5.00", color: "bg-green-500/15 text-green-600 dark:text-green-400 border-green-500/20" },
  { posIndex: 33, tag: "23. Qd8", desc: "Classy back-rank invasion. Pins Bf8 to the king, turns Nc8 into part of a mating net.", evalCp: "+8.06", color: "bg-purple-500/15 text-purple-600 dark:text-purple-400 border-purple-500/20" },
  { posIndex: 35, tag: "24. Ne7+ -- Mating Net", desc: "The knockout: knight checks from c8 to e7, tying queen on d8 and rook on e1 into a mating net on the e-file. Eval jumps to forced mate.", evalCp: "Forced mate", color: "bg-red-500/15 text-red-600 dark:text-red-400 border-red-500/20" },
  { posIndex: 53, tag: "33. Qd4+", desc: "Centralizes queen with check. f7-pawn is pinned. Black's king has no escape squares.", evalCp: "M-in-3", color: "bg-red-500/15 text-red-600 dark:text-red-400 border-red-500/20" },
  { posIndex: 57, tag: "35. Qd7# -- Checkmate", desc: "Queen to d7 covers e6, e8, e7, g7. Rook on d8 covers f8, g8. Every square sealed. Clean mate.", color: "bg-stone-800/15 text-stone-800 dark:text-stone-200 border-stone-500/20" },
];
---

<BaseLayout title={title} description={description}>
  <article class="max-w-4xl mx-auto px-6 py-12 md:py-20 overflow-hidden">
    <!-- Breadcrumbs -->
    <nav class="mb-12 animate-fade-in">
      <a
        href={`${base}blog`}
        class="text-stone-500 dark:text-stone-400 hover:text-copper transition-colors flex items-center gap-2 text-sm font-medium group"
      >
        <svg
          class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Blog
      </a>
    </nav>

    <!-- Header -->
    <header class="mb-16">
      <div class="flex flex-wrap gap-2 mb-6 animate-fade-in">
        {
          tags.map((tag) => (
            <span class="px-3 py-1 bg-copper/10 text-copper text-xs font-bold uppercase tracking-wider rounded-full border border-copper/10">
              {tag}
            </span>
          ))
        }
      </div>

      <h1
        class="font-display text-4xl md:text-6xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight animate-slide-up"
      >
        Nemotron 3 Super 120B vs <span class="text-copper">Stockfish 1400</span>
      </h1>

      <p
        class="text-xl md:text-2xl text-stone-600 dark:text-stone-300 mb-4 animate-slide-up animation-delay-100"
      >
        Oracle Trust Calibration Report — Game 1 of Gauntlet
      </p>

      <div
        class="flex items-center gap-4 text-sm text-stone-400 animate-slide-up animation-delay-200"
      >
        <time datetime={pubDate.toISOString()}>
          {
            pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
        <span>·</span>
        <span>Vario (Mnehmos Research Center)</span>
      </div>
    </header>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- STAT CARDS -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-16 scroll-reveal">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-red-500/10 dark:bg-red-500/15 rounded-2xl p-6 border border-red-500/20">
          <div class="text-xs font-mono font-bold text-red-600 dark:text-red-400 uppercase tracking-wider mb-2">Result</div>
          <div class="text-2xl font-bold text-red-700 dark:text-red-300">0-1</div>
          <div class="text-sm text-red-600/80 dark:text-red-400/80">Checkmate</div>
        </div>
        <div class="bg-amber-500/10 dark:bg-amber-500/15 rounded-2xl p-6 border border-amber-500/20">
          <div class="text-xs font-mono font-bold text-amber-600 dark:text-amber-400 uppercase tracking-wider mb-2">Legal Move Rate</div>
          <div class="text-2xl font-bold text-amber-700 dark:text-amber-300">65%</div>
          <div class="text-sm text-amber-600/80 dark:text-amber-400/80">8 illegal attempts</div>
        </div>
        <div class="bg-stone-500/10 dark:bg-stone-500/15 rounded-2xl p-6 border border-stone-500/20">
          <div class="text-xs font-mono font-bold text-stone-600 dark:text-stone-400 uppercase tracking-wider mb-2">Tokens Burned</div>
          <div class="text-2xl font-bold text-stone-900 dark:text-stone-100">1.33M</div>
          <div class="text-sm text-stone-600/80 dark:text-stone-400/80">586K reasoning</div>
        </div>
        <div class="bg-stone-500/10 dark:bg-stone-500/15 rounded-2xl p-6 border border-stone-500/20">
          <div class="text-xs font-mono font-bold text-stone-600 dark:text-stone-400 uppercase tracking-wider mb-2">Compute Time</div>
          <div class="text-2xl font-bold text-stone-900 dark:text-stone-100">256 min</div>
          <div class="text-sm text-stone-600/80 dark:text-stone-400/80">~12.8 min/move avg</div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- EXECUTIVE SUMMARY -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20 scroll-reveal">
      <div class="bg-stone-900 dark:bg-stone-800 rounded-3xl p-8 md:p-12 text-white">
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-6">Executive Summary</h2>
        <div class="space-y-4 text-stone-300 leading-relaxed">
          <p>
            NVIDIA's newly released <strong class="text-white">Nemotron 3 Super</strong> (120B total / 12B active parameters) was submitted to the Oracle Trust Calibration Framework gauntlet — an eight-tier Stockfish ladder from 1400 to 3190 ELO. The gauntlet was aborted during Match 1, Game 1 after Nemotron lost to <strong class="text-copper">Stockfish at 1400 ELO</strong> by checkmate in 40 moves.
          </p>
          <p>
            This is not a benchmark failure in the traditional sense. It is a <em>cognitive profile</em> — and the profile reveals critical structural gaps between Nemotron's stated capabilities and its actual spatial-tactical reasoning.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- INTERACTIVE CHESS REPLAY -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20 scroll-reveal">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-xs font-mono font-bold px-3 py-1.5 rounded-full bg-copper/15 text-copper border border-copper/20">Interactive</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-stone-900 dark:text-stone-100">
          Game Replay
        </h2>
      </div>
      <p class="text-stone-500 dark:text-stone-400 text-sm mb-6">Use arrow keys or buttons to step through. Click key moments to jump to critical positions.</p>
      <ChessReplay id="nemotron" positions={chessPositions} keyMoments={chessKeyMoments} />
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- MODEL UNDER TEST -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20 scroll-reveal">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-xs font-mono font-bold px-3 py-1.5 rounded-full bg-green-500/15 text-green-600 dark:text-green-400 border border-green-500/20">Model Card</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-stone-900 dark:text-stone-100">
          Model Under Test
        </h2>
      </div>

      <div class="overflow-x-auto mb-8">
        <table class="w-full text-left border-collapse">
          <tbody class="divide-y divide-stone-200 dark:divide-stone-700">
            <tr><td class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-sm w-48">Model</td><td class="py-3 text-stone-900 dark:text-stone-100 font-medium">NVIDIA Nemotron 3 Super 120B-A12B</td></tr>
            <tr><td class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-sm">Architecture</td><td class="py-3 text-stone-900 dark:text-stone-100">Mamba2-Transformer Hybrid LatentMoE + MTP</td></tr>
            <tr><td class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-sm">Total / Active</td><td class="py-3 text-stone-900 dark:text-stone-100">120B / <strong>12B active</strong></td></tr>
            <tr><td class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-sm">Access</td><td class="py-3 text-stone-900 dark:text-stone-100">Free tier via OpenRouter</td></tr>
            <tr><td class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-sm">Prompt Level</td><td class="py-3 text-stone-900 dark:text-stone-100">P6 (full FEN, legal move list, structured output)</td></tr>
            <tr><td class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-sm">Temperature</td><td class="py-3 text-stone-900 dark:text-stone-100">1.0 (NVIDIA recommended default)</td></tr>
            <tr><td class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-sm">Max Retries</td><td class="py-3 text-stone-900 dark:text-stone-100">3</td></tr>
          </tbody>
        </table>
      </div>

      <div class="prose-custom space-y-4 text-stone-600 dark:text-stone-300">
        <p class="leading-relaxed">
          Nemotron 3 Super was released March 12, 2026 — the day this gauntlet began. NVIDIA positions it as their flagship open model for "agentic reasoning, coding, planning, tool calling," trained on 25 trillion tokens with native NVFP4 precision and a 1M-token context window. It scores 85.6% on PinchBench and leads its size class on AIME 2025 and SWE-Bench Verified.
        </p>
        <p class="text-lg font-medium text-stone-900 dark:text-stone-100">
          None of that helped it see a checkmate coming.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- GAME ANALYSIS -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20 scroll-reveal">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-xs font-mono font-bold px-3 py-1.5 rounded-full bg-copper/15 text-copper border border-copper/20">Analysis</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-stone-900 dark:text-stone-100">
          The Anatomy of Collapse
        </h2>
      </div>

      <!-- Phase 1: Opening -->
      <div class="mb-12">
        <h3 class="font-display text-xl font-bold text-stone-900 dark:text-stone-100 mb-4 flex items-center gap-3">
          <span class="text-xs font-mono bg-green-500/15 text-green-600 dark:text-green-400 px-2 py-1 rounded">Moves 7-8</span>
          Competent but Imprecise
        </h3>
        <div class="prose-custom space-y-4 text-stone-600 dark:text-stone-300">
          <p class="leading-relaxed">
            The game began from a Queen's Gambit Declined: Exchange position (ECO D30) with White having a slight edge (+86 cp). Nemotron's first move, <strong class="text-stone-900 dark:text-stone-100">7. Bxf6</strong>, was a reasonable exchange but required two attempts (first was illegal). Move 8, <strong class="text-stone-900 dark:text-stone-100">e4</strong>, showed genuine positional understanding. Evaluation stayed manageable at -31.
          </p>
        </div>
      </div>

      <!-- Phase 2: Collapse -->
      <div class="mb-12 bg-red-500/5 dark:bg-red-500/10 border border-red-500/20 rounded-2xl p-6 md:p-8">
        <h3 class="font-display text-xl font-bold text-red-700 dark:text-red-300 mb-4 flex items-center gap-3">
          <span class="text-xs font-mono bg-red-500/15 text-red-600 dark:text-red-400 px-2 py-1 rounded">Move 9</span>
          The Collapse Point: d5
        </h3>
        <div class="space-y-4 text-stone-600 dark:text-stone-300">
          <p class="leading-relaxed">
            This is where the game broke. Nemotron played <strong class="text-red-700 dark:text-red-300">9. d5</strong> — a pawn push that the Oracle evaluated as a <strong class="text-red-700 dark:text-red-300">-397 centipawn swing</strong>. The engine's top move was <code class="bg-stone-200 dark:bg-stone-700 px-1.5 py-0.5 rounded text-sm font-mono">e4f3</code>. Nemotron's reasoning was fluent and confident:
          </p>
          <blockquote class="border-l-4 border-copper bg-stone-100 dark:bg-stone-800 py-3 px-5 rounded-r-xl text-stone-700 dark:text-stone-300 italic">
            "The move d5 challenges black's e4 pawn, gains space, and opens lines for white's pieces..."
          </blockquote>
          <p class="leading-relaxed">
            This is a textbook example of what we call <strong class="text-stone-900 dark:text-stone-100">coherent confabulation</strong> — the reasoning sounds strategically correct but maps to a tactically losing position. The model correctly identified strategic themes (central space, development advantage) but failed to detect the concrete tactical refutation.
          </p>
        </div>
      </div>

      <!-- Phase 3: Phantom Board -->
      <div class="mb-12">
        <h3 class="font-display text-xl font-bold text-stone-900 dark:text-stone-100 mb-4 flex items-center gap-3">
          <span class="text-xs font-mono bg-amber-500/15 text-amber-600 dark:text-amber-400 px-2 py-1 rounded">Moves 13-14</span>
          The Hallucinated Fork
        </h3>
        <div class="prose-custom space-y-4 text-stone-600 dark:text-stone-300">
          <p class="leading-relaxed">
            By move 13, Nemotron played <strong class="text-stone-900 dark:text-stone-100">Nc6</strong>, claiming it "creates a fork, attacking both the queen on d8 and the rook on a8." By move 14, <strong class="text-stone-900 dark:text-stone-100">Nb5</strong> at -940 cp, Nemotron's reasoning stated: "our knight on c5 attacks three black pawns."
          </p>
          <p class="text-lg font-medium text-amber-700 dark:text-amber-300">
            The knight was not on c5.
          </p>
          <p class="leading-relaxed">
            Nemotron was narrating a position that did not exist on the board — a <strong class="text-stone-900 dark:text-stone-100">phantom board state</strong>. The Oracle's top move was simply capturing back on c6.
          </p>
        </div>
      </div>

      <!-- Phase 4: King Walk -->
      <div class="mb-12 bg-stone-100 dark:bg-stone-800 rounded-2xl p-6 md:p-8 border border-stone-200 dark:border-stone-700">
        <h3 class="font-display text-xl font-bold text-stone-900 dark:text-stone-100 mb-4 flex items-center gap-3">
          <span class="text-xs font-mono bg-stone-500/15 text-stone-600 dark:text-stone-400 px-2 py-1 rounded">Moves 17-26</span>
          The King Walk: Reasoning Without Reality
        </h3>
        <div class="space-y-4 text-stone-600 dark:text-stone-300">
          <p class="leading-relaxed">
            From move 17 onward, the position was already lost (mate-in-N detected by Stockfish). Nemotron's king embarked on a tour:
          </p>
          <div class="font-mono text-sm bg-stone-200 dark:bg-stone-900 rounded-xl p-4 text-stone-700 dark:text-stone-300 overflow-x-auto">
            Kd2 → Ke3 → Ke2 → Kd1 → Kc2 → Kd1 → Kc1 → Kd1 → Ke2 → Qe1#
          </div>
          <p class="leading-relaxed">
            Each move accompanied by detailed tactical analysis. Move 18: <em>"Ke3 directly defends the f3 pawn..."</em> — while the Oracle screamed for Rb2, spotting forced mate. Move 19: <em>"The only way to meet this check while gaining material is to capture the queen..."</em> — Nemotron believed it could capture Black's queen. It could not.
          </p>
          <p class="leading-relaxed">
            Move 26: <strong class="text-red-700 dark:text-red-300">Ke2</strong> into <strong class="text-red-700 dark:text-red-300">Qe1#</strong>. Checkmate. The model consumed <strong class="text-stone-900 dark:text-stone-100">2.58 million milliseconds</strong> (43 minutes) and <strong class="text-stone-900 dark:text-stone-100">194,612 tokens</strong> on its final move.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- PERFORMANCE TABLE -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20 scroll-reveal">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-xs font-mono font-bold px-3 py-1.5 rounded-full bg-blue-500/15 text-blue-600 dark:text-blue-400 border border-blue-500/20">Data</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-stone-900 dark:text-stone-100">
          Statistical Profile
        </h2>
      </div>

      <!-- Performance Comparison -->
      <div class="overflow-x-auto mb-12">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b-2 border-stone-300 dark:border-stone-600">
              <th class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-xs uppercase tracking-wider">Metric</th>
              <th class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-xs uppercase tracking-wider">Nemotron (White)</th>
              <th class="py-3 text-stone-500 dark:text-stone-400 font-mono text-xs uppercase tracking-wider">Stockfish 1400 (Black)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-200 dark:divide-stone-700">
            <tr><td class="py-3 pr-4 text-stone-600 dark:text-stone-300">Total Moves</td><td class="py-3 pr-4 font-medium text-stone-900 dark:text-stone-100">20</td><td class="py-3 font-medium text-stone-900 dark:text-stone-100">20</td></tr>
            <tr><td class="py-3 pr-4 text-stone-600 dark:text-stone-300">Illegal Attempts</td><td class="py-3 pr-4 font-medium text-red-700 dark:text-red-400">8</td><td class="py-3 font-medium text-green-700 dark:text-green-400">0</td></tr>
            <tr><td class="py-3 pr-4 text-stone-600 dark:text-stone-300">Legal Move Rate</td><td class="py-3 pr-4 font-medium text-amber-700 dark:text-amber-400">65%</td><td class="py-3 font-medium text-green-700 dark:text-green-400">100%</td></tr>
            <tr><td class="py-3 pr-4 text-stone-600 dark:text-stone-300">Avg Response Time</td><td class="py-3 pr-4 font-medium text-stone-900 dark:text-stone-100">767,405 ms (~12.8 min)</td><td class="py-3 font-medium text-stone-900 dark:text-stone-100">1,680 ms</td></tr>
            <tr><td class="py-3 pr-4 text-stone-600 dark:text-stone-300">Total Tokens</td><td class="py-3 pr-4 font-medium text-stone-900 dark:text-stone-100">1,330,396</td><td class="py-3 font-medium text-stone-400">N/A</td></tr>
            <tr><td class="py-3 pr-4 text-stone-600 dark:text-stone-300">Reasoning Tokens</td><td class="py-3 pr-4 font-medium text-stone-900 dark:text-stone-100">586,482 (44%)</td><td class="py-3 font-medium text-stone-400">N/A</td></tr>
            <tr><td class="py-3 pr-4 text-stone-600 dark:text-stone-300">Avg TPS</td><td class="py-3 pr-4 font-medium text-stone-900 dark:text-stone-100">55.5</td><td class="py-3 font-medium text-stone-400">N/A</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Think-Time by Phase -->
      <h3 class="font-display text-xl font-bold text-stone-900 dark:text-stone-100 mb-4">Think-Time by Phase</h3>
      <div class="overflow-x-auto mb-12">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b-2 border-stone-300 dark:border-stone-600">
              <th class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-xs uppercase tracking-wider">Phase</th>
              <th class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-xs uppercase tracking-wider">Avg Think</th>
              <th class="py-3 pr-4 text-stone-500 dark:text-stone-400 font-mono text-xs uppercase tracking-wider">Avg Tokens</th>
              <th class="py-3 text-stone-500 dark:text-stone-400 font-mono text-xs uppercase tracking-wider">Pattern</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-200 dark:divide-stone-700">
